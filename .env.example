# --- Database ---
# SQLite file path. The default puts it under ./data so it can be a docker volume.
DATABASE_URL=sqlite:///./data/event_bridge.db

# --- Application ---
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=False

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-secret-key-in-production

# Bootstrap admin account, created on first start if it doesn't exist.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# JWT cookie name and lifetime (in minutes).
JWT_COOKIE_NAME=event_bridge_session
JWT_EXPIRE_MINUTES=10080

# --- Forwarder ---
# Hard limit on retries before a request is moved to the dead_letter table.
FORWARD_MAX_ATTEMPTS=5
# Exponential backoff base in seconds: attempt N waits BASE * 2**(N-1).
FORWARD_BASE_BACKOFF_SECONDS=1.0
# Per-destination HTTP timeout.
FORWARD_HTTP_TIMEOUT_SECONDS=10

# --- Retention ---
# Older webhook_request rows are deleted by the retention sweep.
WEBHOOK_RETENTION_DAYS=30
